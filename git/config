[credential]
   helper = store
[merge]
	tool = vimdiff
[mergetool "vimdiff"]
	cmd = nvim -d $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'
[add.interactive]
   useBuiltin = false # required for git 2.37.0
[init]
	defaultBranch = master

[diff]
    tool = difftastic
    external = difft
[difftool "difftastic"]
    cmd = difft "$LOCAL" "$REMOTE"
[difftool]
    prompt = false

[include]
   path = ~/.gitconfig.local

